APP_NAME=FlowSense
APP_VERSION=2.0.7
HOST=127.0.0.1
PORT=8000
DATABASE_URL=sqlite:///./data/flowsense.db
DATA_DIR=./data
LOG_LEVEL=INFO

# Optional: enable Gemini workflow naming
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_TOKENS=300
GEMINI_TIMEOUT_SECONDS=15

WORKFLOW_MIN_CONFIDENCE=0.75
WORKFLOW_MIN_FREQUENCY=3
WORKFLOW_MIN_STEPS=3
WORKFLOW_MAX_STEPS=8
WORKFLOW_MAX_GAP_MINUTES=10
