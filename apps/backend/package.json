{
  "name": "@flowsense/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
    "start": "uvicorn app.main:app --host 127.0.0.1 --port 8000",
    "build": "python -m compileall -q app",
    "test": "python -m pytest",
    "lint": "python -m ruff check app tests",
    "format": "python -m ruff format app tests",
    "typecheck": "python -m mypy app"
  }
}
