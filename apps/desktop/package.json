{
  "name": "flowsense-desktop",
  "version": "2.0.7",
  "private": true,
  "author": "Subham",
  "description": "FlowSense — AI-powered desktop focus companion",
  "main": "out/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@flowsense/shared": "file:../../packages/shared",
    "@tanstack/react-query": "^5.59.0",
    "clsx": "^2.1.1",
    "electron-store": "^10.0.0",
    "framer-motion": "^11.11.0",
    "lucide-react": "^0.451.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.20",
    "electron": "43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.46.1",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.flowsense.desktop",
    "productName": "FlowSense",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "out/**/*",
      "public/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "!**/__pycache__/**",
          "!**/.pytest_cache/**",
          "!**/.ruff_cache/**",
          "!**/tests/**",
          "!**/.env",
          "!**/data/**"
        ]
      },
      {
        "from": "../../vendor/python",
        "to": "vendor/python",
        "filter": [
          "!**/__pycache__/**"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "include": "build/installer.nsh",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "menuCategory": "FlowSense",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": true,
      "warningsAsErrors": false
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
